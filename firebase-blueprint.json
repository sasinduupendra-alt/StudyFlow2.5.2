{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User's gamification stats and profile info",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "targetExam": { "type": "string" },
        "dailyGoalMinutes": { "type": "number" },
        "level": { "type": "number" },
        "streak": { "type": "number" },
        "xp": { "type": "number" },
        "xpToNextLevel": { "type": "number" },
        "points": { "type": "number" },
        "totalSessions": { "type": "number" },
        "totalStudyTime": { "type": "number" },
        "badges": {
          "type": "array",
          "items": { "schema": "Badge" }
        }
      },
      "required": ["email", "displayName", "joinedAt", "level", "streak", "xp", "points"]
    },
    "Badge": {
      "title": "Badge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "type": { "type": "string" },
        "requirement": { "type": "number" },
        "unlockedAt": { "type": "string", "format": "date-time" }
      }
    },
    "StudyLog": {
      "title": "StudyLog",
      "description": "A record of a single study session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "topicIds": { "type": "array", "items": { "type": "string" } },
        "topicId": { "type": "string" },
        "duration": { "type": "number" },
        "focusLevel": { "type": "number" },
        "performance": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "sessionType": { "type": "string" }
      },
      "required": ["id", "subjectId", "duration", "focusLevel", "timestamp"]
    },
    "ExamRecord": {
      "title": "ExamRecord",
      "description": "A record of an exam result",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "subjectId": { "type": "string" },
        "score": { "type": "number" },
        "marks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subjectId": { "type": "string" },
              "score": { "type": "number" }
            }
          }
        },
        "totalScore": { "type": "number" },
        "averageScore": { "type": "number" },
        "rank": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "title", "date", "totalScore", "averageScore"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A subject in the user's syllabus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": "number" },
        "focus": { "type": "number" },
        "weakCount": { "type": "number" },
        "status": { "type": "string" },
        "priorityScore": { "type": "number" },
        "readiness": { "type": "number" },
        "gradient": { "type": "string" },
        "image": { "type": "string" },
        "examDate": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "topics": {
          "type": "array",
          "items": { "schema": "Topic" }
        }
      },
      "required": ["id", "name", "topics"]
    },
    "Topic": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "mastery": { "type": "number" },
        "image": { "type": "string" },
        "lastReviewed": { "type": "string", "format": "date-time" },
        "nextReview": { "type": "string", "format": "date-time" },
        "interval": { "type": "number" },
        "easeFactor": { "type": "number" },
        "reviewCount": { "type": "number" }
      }
    },
    "WeeklySchedule": {
      "title": "WeeklySchedule",
      "description": "User's weekly study schedule",
      "type": "object",
      "properties": {
        "Monday": { "type": "array", "items": { "schema": "Activity" } },
        "Tuesday": { "type": "array", "items": { "schema": "Activity" } },
        "Wednesday": { "type": "array", "items": { "schema": "Activity" } },
        "Thursday": { "type": "array", "items": { "schema": "Activity" } },
        "Friday": { "type": "array", "items": { "schema": "Activity" } },
        "Saturday": { "type": "array", "items": { "schema": "Activity" } },
        "Sunday": { "type": "array", "items": { "schema": "Activity" } }
      }
    },
    "Activity": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["study", "tuition", "break", "rest"] }
      }
    },
    "Task": {
      "title": "Task",
      "description": "A study task with SNR prioritization",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "frequency": { "type": "string" },
        "completed": { "type": "boolean" },
        "subjectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "impact": { "type": "number" },
        "effort": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "frequency", "completed", "createdAt", "impact", "effort"]
    },
    "NoiseLog": {
      "title": "NoiseLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "level": { "type": "number" }
      },
      "required": ["id", "timestamp", "source", "level"]
    },
    "NotificationPreferences": {
      "title": "NotificationPreferences",
      "type": "object",
      "properties": {
        "dailyReminders": { "type": "boolean" },
        "achievementNotifications": { "type": "boolean" },
        "studyTips": { "type": "boolean" },
        "systemAlerts": { "type": "boolean" },
        "aiRecommendations": { "type": "boolean" },
        "reviewReminders": { "type": "boolean" },
        "emailNotifications": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and gamification data"
    },
    "/users/{userId}/study_logs/{logId}": {
      "schema": "StudyLog",
      "description": "History of study sessions"
    },
    "/users/{userId}/exams/{examId}": {
      "schema": "ExamRecord",
      "description": "History of exam results"
    },
    "/users/{userId}/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "User's custom syllabus subjects"
    },
    "/users/{userId}/config/schedule": {
      "schema": "WeeklySchedule",
      "description": "User's weekly study schedule"
    },
    "/users/{userId}/config/notifications": {
      "schema": "NotificationPreferences",
      "description": "User's notification settings"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User's study tasks"
    },
    "/users/{userId}/noise_logs/{noiseId}": {
      "schema": "NoiseLog",
      "description": "History of detected noise/distractions"
    }
  }
}
